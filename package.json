{
  "name": "hf-dataset-distill",
  "version": "1.0.0",
  "description": "An project to help with distillation of models to get dataset with Batch API (50% discount)",
  "main": "src/app.ts",
  "scripts": {
    "start": "bun run --bun .",
    "dev": "bun run --bun --watch .",
    "migrate": "drizzle-kit migrate",
    "up": "drizzle-kit generate && bun run migrate",
    "export": "bun run --bun ./src/commands/export.ts",
    "stat": "bun run --bun ./src/commands/stat.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/dalisoft/hf-dataset-distill"
  },
  "keywords": [],
  "author": "Davlatjon Shavkatov <opensource@dalisoft.uz>",
  "license": "Apache-2.0",
  "type": "module",
  "devDependencies": {
    "@libsql/client": "^0.17.0",
    "@types/bun": "^1.3.10",
    "drizzle-kit": "^0.31.9",
    "prettier": "^3.8.1",
    "prettier-config-airlight": "^6.0.5",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@anthropic-ai/tokenizer": "^0.0.4",
    "drizzle-orm": "^0.45.1",
    "tss-env": "^0.0.3"
  }
}
