  "description": "This is a reasoning dataset created using [Claude Haiku 4.5](https://openrouter.ai/anthropic/claude-haiku-4.5) with reasoning effort set to high.",
  "main": "src/app.ts",
  "scripts": {
    "start": "bun run --bun .",
