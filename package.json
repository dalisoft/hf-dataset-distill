    "prettier": "^3.8.1",
    "prettier-config-airlight": "^6.0.5",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.1",
    "tss-env": "^0.0.3"
  }
